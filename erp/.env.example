# Database
DATABASE_URL=postgresql://user:password@localhost:5432/candid_carnival
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Payment Gateways
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET_KEY=your_razorpay_secret_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# File Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=candid-carnival-bucket

# Notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

SENDGRID_API_KEY=your_sendgrid_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Backend
NODE_ENV=development
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Business Settings
BUSINESS_NAME=Candid Carnival
BUSINESS_EMAIL=info@candidcarnival.com
BUSINESS_PHONE=+91-XXXXXXXXXX
BUSINESS_ADDRESS=Bangalore, India
GST_NUMBER=27XXXXXXXXXXXXX

# Feature Flags
ENABLE_STRIPE=true
ENABLE_RAZORPAY=true
ENABLE_AI_FEATURES=true
ENABLE_NOTIFICATIONS=true